#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/outputs.h>
#include "keypos_34keys.h"

#define _BASE    0
#define _NAV     1
#define _SYM     2
#define _BTF     3
#define _GAME    4

#define RGB_BASE RGB_COLOR_HSB(0,100,4)
#define RGB_SYM RGB_COLOR_HSB(40,100,4)
#define RGB_NAV RGB_COLOR_HSB(130,100,5)
#define RGB_BTF RGB_COLOR_HSB(230,100,5)
#define RGB_GAME RGB_COLOR_HSB(80,180, 40)

&sk {
    quick-release;
};

/ {
// ------------------------- MACROS --------------------------------
    macros {
        to_BASE: to_BASE {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&rgb_ug RGB_OFF>
                , <&tog _NAV>
                ;
        };

        to_NAV: to_NAV {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&rgb_ug RGB_ON>
                , <&rgb_ug RGB_NAV>
                , <&tog _NAV>
                ;
        };

        to_GAME: to_GAME {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&rgb_ug RGB_ON>
                , <&rgb_ug RGB_GAME>
                , <&tog _GAME>
                ;
        };

        mo_BTF: mo_BTF {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&macro_tap &rgb_ug RGB_ON>
                , <&macro_tap &rgb_ug RGB_BTF>
                , <&macro_press &mo _BTF>
                , <&macro_pause_for_release>
                , <&macro_tap &rgb_ug RGB_OFF>
                , <&macro_release &mo _BTF>
                ;
        };

        to_BOOT: to_BOOT {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&rgb_ug RGB_COLOR_HSB(0,100,50)>
                , <&rgb_ug RGB_ON>
                , <&bootloader>
                ;
        };
    };

    combos {
        compatible = "zmk,combos";
// ------------------------- LAYER COMBOS --------------------------------
        combo_BTF1 {
            timeout-ms = <50>;
            key-positions = <LHI RHI>;
            bindings = <&mo_BTF>;
            layers = <_BASE _SYM _NAV>;
        };

        combo_BTF2 {
            timeout-ms = <50>;
            key-positions = <LHI LHO>;
            bindings = <&mo_BTF>;
            layers = <_BASE _SYM _NAV>;
        };

        combo_BTF3 {
            timeout-ms = <50>;
            key-positions = <RHO RHI>;
            bindings = <&mo_BTF>;
            layers = <_BASE _SYM _NAV>;
        };

        combo_NAVR {
            timeout-ms = <50>;
            key-positions = <RMR RMM RMI>;
            bindings = <&to_NAV>;
            layers = <_BASE _SYM>;
        };

        combo_GAME {
            timeout-ms = <50>;
            key-positions = <LMR LMM LMI>;
            bindings = <&to_GAME>;
            layers = <_BASE _SYM>;
        };

        combo_BASER {
            timeout-ms = <50>;
            key-positions = <RMR RMM RMI>;
            bindings = <&to_BASE>;
            layers = <_NAV _GAME>;
        };

        combo_BASEL {
            timeout-ms = <50>;
            key-positions = <LMR LMM LMI>;
            bindings = <&to_BASE>;
            layers = <_NAV _GAME>;
        };

// ------------------------- UTILITY COMBOS --------------------------------
        combo_BOOT {
            timeout-ms = <50>;
            key-positions = <LBP LHI LHO>;
            bindings = <&to_BOOT>;
        };

        combo_UNLCK {
            timeout-ms = <200>;
            key-positions = <LTC LBC RTC RBC>;
            bindings = <&studio_unlock>;
            layers = <_BASE>;
            require-prior-idle-ms = <200>;
        };

// ------------------------- MODS COMBOS --------------------------------
        combo_CAPS {
            timeout-ms = <60>;
            key-positions = <LMP RMP>;
            bindings = <&caps_word>;
            require-prior-idle-ms = <200>;
            layers = <_BASE>;
        };

      combo_TAB {
            timeout-ms = <50>;
            key-positions = <LTR LTP>;
            bindings = <&kp TAB>;
            layers = <_BASE _SYM>;
        };

        combo_ESC {
            timeout-ms = <50>;
            key-positions = <LMR LMP>;
            bindings = <&kp ESC>;
            layers = <_BASE _SYM>;
        };

        combo_BSPC {
            timeout-ms = <50>;
            key-positions = <RTP RTR>;
            bindings = <&kp BSPC>;
            layers = <_BASE _SYM>;
        };

    };

    behaviors {
// ------------------------- HOLD-TAPS --------------------------------
        /* left-hand HRMs */
        hml: hrm_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <250>;
            quick-tap-ms = <150>;                // repeat on tap-into-hold
            require-prior-idle-ms = <150>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <KEYS_R THUMBS>;
            hold-trigger-on-release;             // delay positional check until key-release
        };

        /* right-hand HRMs */
        hmr: hrm_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <250>;
            quick-tap-ms = <150>;                // repeat on tap-into-hold
            require-prior-idle-ms = <150>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <KEYS_L THUMBS>;
            hold-trigger-on-release;             // delay positional check until key-release
        };

        tht: thumbs-tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            quick-tap-ms = <120>;
            require-prior-idle-ms = <100>;
            bindings = <&mo>, <&kp>;
        };

    };

    keymap {
        compatible = "zmk,keymap";

                base_layer {
                    display-name = "Base";
// -------------------------------    -------------------------------
// |  Q  |  W  |  E  |  R  |  T  |    |  Y  |  U  |  I  |  O  |  P  |
// |  A  |  S  |  D  |  F  |  G  |    |  H  |  J  |  K  |  L  |  ;  |
// |  Z  |  X  |  C  |  V  |  B  |    |  N  |  M  |  ,  |  .  |  '  |
//       | _SYM(ESC) | _NAV(SPC) |    | _SYM(BSPC) | _NAV(RET) |
                        bindings = <
   &kp Q        &kp W        &kp E       &kp R       &kp T     &kp Y  &kp U       &kp I       &kp O        &kp P
   &hml LSHFT A &hml LCTRL S &hml LALT D &hml LGUI F &kp G     &kp H  &hmr LGUI J &hmr LALT K &hmr LCTRL L &hmr LSHFT SEMI
   &kp Z        &kp X        &kp C       &kp V       &kp B     &kp N  &kp M       &kp COMMA   &kp DOT      &kp SLASH
                            &tht _SYM TAB  &tht _NAV SPACE     &tht _SYM RET  &tht _NAV BSPC
                        >;
                };

                nav_layer {
                    display-name = "Navi";
// -------------------------------    -----------------------------------
// |  {  |  }  |  <  |  >  | PSC |    | ESC | HOME | PGDN | PGUP | END  |
// |  [  |  ]  |  (  |  )  | APP |    | TAB | LEFT | DOWN |  UP  | RGHT |
// | BR- | BR+ |  V- | V+  | V.  |    | INS | BSPC | SPC  | DEL  | RET  |
//       | _SYM(ESC) | _NAV(SPC) |    | _SYM(BSPC) | _NAV(RET) |
                        bindings = <
   &kp LBKT       &kp RBKT       &kp LT         &kp GT         &kp PSCRN     &kp ESC    &kp HOME       &kp PG_DN      &kp PG_UP     &kp END
   &hml LSHFT LBKT &hml LCTRL RBKT &hml LALT LPAR &hml LGUI RPAR &kp K_APP     &kp LEFT    &hmr LGUI DOWN &hmr LALT UP &hmr LCTRL RIGHT &hmr LSHFT ESC
   &kp C_BRI_DN    &kp C_BRI_UP    &kp C_VOL_DN   &kp C_VOL_UP   &kp C_MUTE    &kp INS    &kp BSPC       &kp SPACE      &kp DEL       &kp RET
                            &tht _SYM TAB  &tht _NAV SPACE     &tht _SYM RET  &tht _NAV BSPC
                        >;
                };

                sym_layer {
                    display-name = "Sym-Num";
// -------------------------------    -------------------------------
// |  !  |  @  |  #  |  $  |  %  |    |  ^  |  &  |  *  |  ?  |  :  |
// |  1  |  2  |  3  |  4  |  5  |    |  6  |  7  |  8  |  9  |  0  |
// |  |  |  \  |  =  |  +  |  `  |    |  ~  |  -  |  _  |  /  |  "  |
//       | _SYM(ESC) | _NAV(SPC) |    | _SYM(BSPC) | _NAV(RET) |
                        bindings = <
   &kp EXCL      &kp AT        &kp HASH     &kp DLLR     &kp PRCNT     &kp CARET &kp AMPS     &kp STAR     &kp LPAR     &kp RPAR
   &hml LSHFT N1 &hml LCTRL N2 &hml LALT N3 &hml LGUI N4 &kp N5        &kp N6    &hmr LGUI N7 &hmr LALT N8 &hmr LCTRL N9 &hmr LSHFT N0
   &kp PIPE      &kp BSLH      &kp EQUAL    &kp PLUS     &kp GRAVE     &kp TILDE &kp MINUS    &kp UNDER    &kp SLASH     &kp DQT
                            &tht _SYM TAB  &tht _NAV SPACE     &tht _SYM RET  &tht _NAV BSPC
                        >;
                };

                btf_layer {
                    display-name = "BT-Func";
// -----------------------------------    -------------------------------
// | BT1  | BT2  | BT3  | BT4  | BT5 |    | F1  | F2  | F3  | F4  | F5  |
// | SFT  | CTL  | ALT  | GUI  | USB |    | F6  | F7  | F8  | F9  | F10 |
// | uTOG | uEFF | uSP- | uSP+ | CLR |    | F11 | F12 | F13 | F14 | F15 |
//                       |     |     |    |    |     |
                        bindings = <
   &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &bt BT_SEL 3    &bt BT_SEL 4   &kp F1  &kp F2  &kp F3  &kp F4  &kp F5
   &kp LSHIFT      &kp LCTRL       &kp LALT        &kp LGUI        &out OUT_TOG   &kp F6  &kp F7  &kp F8  &kp F9  &kp F10
   &rgb_ug RGB_TOG &rgb_ug RGB_EFF &rgb_ug RGB_SPD &rgb_ug RGB_SPI &bt BT_CLR     &kp F11 &kp F12 &kp F13 &kp F14 &kp F15
                                                            &none   &none         &none  &none
                        >;
                };

                game_layer {
                    display-name = "Game";
// -------------------------------    -------------------------------
// |  Q  |  W  |  E  |  R  |  T  |    |  Y  |  U  |  I  |  O  |  P  |
// |  A  |  S  |  D  |  F  |  G  |    |  H  |  J  |  K  |  L  |  ;  |
// |  Z  |  X  |  C  |  V  |  B  |    |  N  |  M  |  ,  |  .  |  '  |
//       | _SYM(ESC) | _NAV(SPC) |    | _SYM(BSPC) | _NAV(RET) |
                        bindings = <
   &kp Q        &kp W        &kp E       &kp R       &kp T     &kp Y  &kp U       &kp I       &kp O        &kp P
   &kp A        &kp S        &kp D       &kp F       &kp G     &kp H  &kp J       &kp K       &kp L        &kp LSHIFT
   &kp Z        &kp X        &kp C       &kp V       &kp B     &kp N  &kp M       &kp COMMA   &kp DOT      &kp LCTRL
                                          &kp TAB   &kp SPACE   &kp RET   &kp BSPC
                        >;
                };
    };
};
